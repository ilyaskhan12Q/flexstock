# ── App Configuration ───────────────────────────
APP_NAME="FlexStock"
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# ── Database Configuration ──────────────────────
DATABASE_URL="postgresql://postgres:postgres_secure_password@localhost:5432/flexstock?schema=public"

# ── Authentication Secrets ──────────────────────
# You should generate long random strings for these in production
JWT_SECRET="super-secret-flexstock-jwt-key"
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET="super-secret-flexstock-refresh-key"

# ── Currency & Locale Settings ──────────────────
CURRENCY_SYMBOL="PKR"
DATE_FORMAT="DD/MM/YYYY"

# ── Optional Modules ────────────────────────────
SALES_MODULE=true
THERMAL_PRINTING=false
LABEL_TEMPLATE="2x4" # Options: 2x4 | 3x5 | single

# ── SMTP Email Alert Details (Optional) ─────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
ALERT_EMAIL=""
