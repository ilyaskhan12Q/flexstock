{
  "name": "flexstock-monorepo",
  "version": "1.1.0",
  "description": "FlexStock Monorepo",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "prisma:generate": "npm run prisma:generate --workspace=server",
    "prisma:migrate": "npm run prisma:migrate --workspace=server",
    "prisma:seed": "npm run prisma:seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
